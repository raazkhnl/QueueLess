# ===================================================
# QueueLess API — Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ===================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB — use a strong unique password in production
# Format: mongodb+srv://<user>:<password>@<cluster>/<dbname>
MONGO_URI=mongodb://localhost:27017/queueless

# JWT — CHANGE THIS in production! Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_crypto_random_64_bytes
JWT_EXPIRES_IN=7d

# Email (Sender.net SMTP)
SENDER_API_TOKEN=your_sender_net_api_token
SENDER_FROM_EMAIL=noreply@queueless.app

# Frontend URL (for email links and CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# Logging
LOG_LEVEL=info

# No-Show Auto-Mark (grace period in minutes after appointment end time)
NO_SHOW_GRACE_MINUTES=30
